{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/protect-results-csv.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/protect-root.sh"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/validate-finds.sh"
          },
          {
            "type": "command",
            "command": ".claude/hooks/validate-dealer-output.sh"
          }
        ]
      }
    ]
  }
}
